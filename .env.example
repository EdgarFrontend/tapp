# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# The port where Express server will run locally
PORT=3000

# The URL of the Mini App.
# For local browser testing, this can be http://localhost:3000
# For Telegram integration, this must be an HTTPS URL (e.g. from ngrok)
MINI_APP_URL=http://localhost:3000
